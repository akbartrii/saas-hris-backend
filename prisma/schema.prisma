generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ms_companies {
  id                       String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String                        @db.VarChar(255)
  code                     String?                       @unique @db.VarChar(50)
  address                  String?
  phone                    String?                       @db.VarChar(20)
  email                    String?                       @db.VarChar(255)
  npwp                     String?                       @db.VarChar(50)
  is_active                Boolean?                      @default(true)
  created_at               DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                     @default(now()) @db.Timestamptz(6)
  ms_departments           ms_departments[]
  ms_holiday_calendars     ms_holiday_calendars[]
  ms_job_postings          ms_job_postings[]
  ms_locations             ms_locations[]
  tr_payroll_periods       tr_payroll_periods[]
  ms_users                 ms_users[]
  msLeaveTypes             ms_leave_types[]
  msOvertimeMealAllowances ms_overtime_meal_allowances[]
  msTimeOffTypes           ms_time_off_types[]
  msWorkSchedules          ms_work_schedules[]
  msParameters             ms_parameters[]
  ms_subscriptions         ms_subscriptions[]
  ms_usage_tracking        ms_usage_tracking[]
  ms_roles                 ms_roles[]
}

model ms_departments {
  id                                                         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id                                                 String            @db.Uuid
  name                                                       String            @db.VarChar(255)
  code                                                       String?           @db.VarChar(50)
  head_employee_id                                           String?           @db.Uuid
  created_at                                                 DateTime?         @default(now()) @db.Timestamptz(6)
  ms_employees_ms_departments_head_employee_idToms_employees ms_employees?     @relation("ms_departments_head_employee_idToms_employees", fields: [head_employee_id], references: [id], onUpdate: NoAction, map: "fk_departments_head_employee")
  ms_companies                                               ms_companies      @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ms_job_postings                                            ms_job_postings[]
  ms_positions                                               ms_positions[]
  ms_employees_ms_employees_department_idToms_departments    ms_employees[]    @relation("ms_employees_department_idToms_departments")
  ms_teams                                                   ms_teams[]

  @@index([company_id], map: "idx_departments_company")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ms_holiday_calendars {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id   String       @db.Uuid
  holiday_date DateTime     @db.Date
  name         String       @db.VarChar(255)
  type         String       @db.VarChar(50)
  is_recurring Boolean?     @default(false)
  year         Int
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)
  ms_companies ms_companies @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([company_id, holiday_date])
  @@index([company_id, holiday_date], map: "idx_holiday_calendars_company_date")
  @@index([year], map: "idx_holiday_calendars_year")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ms_job_postings {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id          String                @db.Uuid
  title               String                @db.VarChar(255)
  department_id       String?               @db.Uuid
  position_id         String?               @db.Uuid
  location_id         String?               @db.Uuid
  description         String
  requirements        String?
  employment_type     String?               @db.VarChar(50)
  status              String?               @default("draft") @db.VarChar(50)
  public_slug         String?               @unique @db.VarChar(255)
  opened_at           DateTime?             @db.Date
  closed_at           DateTime?             @db.Date
  created_by          String?               @db.Uuid
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  ms_users            ms_users?             @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_job_postings_created_by")
  ms_companies        ms_companies          @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ms_departments      ms_departments?       @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  ms_locations        ms_locations?         @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  ms_positions        ms_positions?         @relation(fields: [position_id], references: [id], onUpdate: NoAction)
  tr_job_applications tr_job_applications[]

  @@index([public_slug], map: "idx_job_postings_slug")
  @@index([status], map: "idx_job_postings_status")
}

model ms_leave_types {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id           String              @db.Uuid
  name                 String              @db.VarChar(255)
  code                 String?             @unique @db.VarChar(50)
  default_days         Int?                @default(0)
  is_annual            Boolean?            @default(false)
  is_paid              Boolean?            @default(true)
  requires_attachment  Boolean?            @default(false)
  max_days_per_request Int?
  created_at           DateTime?           @default(now()) @db.Timestamptz(6)
  tr_leave_balances    tr_leave_balances[]
  tr_leave_requests    tr_leave_requests[]
  ms_companies         ms_companies        @relation(fields: [company_id], references: [id])

  @@index([company_id], map: "idx_leave_types_company")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ms_locations {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id      String            @db.Uuid
  name            String            @db.VarChar(255)
