model ms_roles {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String?              @db.Uuid
  name          String               @db.VarChar(100)
  display_name  String?              @db.VarChar(255)
  permissions   Json?                @default("[]")
  is_active     Boolean?             @default(true)
  created_at    DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?            @updatedAt @db.Timestamptz(6)
  ms_users      ms_users[]
  companies     ms_companies?        @relation(fields: [company_id], references: [id])
  role_permissions ms_role_permissions[]

  @@unique([company_id, name])
  @@index([company_id], map: "idx_roles_company")
}

model ms_menus {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String         @unique @db.VarChar(100)
  name       String         @db.VarChar(255)
  icon       String?        @db.VarChar(100)
  parent_id  String?        @db.Uuid
  sort_order Int            @default(0)
  is_active  Boolean?       @default(true)
  created_at DateTime?      @default(now()) @db.Timestamptz(6)

  parent      ms_menus?        @relation("menu_hierarchy", fields: [parent_id], references: [id])
  children    ms_menus[]       @relation("menu_hierarchy")
  permissions ms_permissions[]

  @@index([parent_id], map: "idx_menus_parent")
}

model ms_permissions {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menu_id     String               @db.Uuid
  action      String               @db.VarChar(50)
  description String?              @db.VarChar(255)
  created_at  DateTime?            @default(now()) @db.Timestamptz(6)

  menu            ms_menus              @relation(fields: [menu_id], references: [id])
  role_permissions ms_role_permissions[]

  @@unique([menu_id, action])
  @@index([menu_id], map: "idx_permissions_menu")
}

model ms_role_permissions {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String    @db.Uuid
  permission_id String    @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  role       ms_roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission ms_permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@index([role_id], map: "idx_role_permissions_role")
  @@index([permission_id], map: "idx_role_permissions_permission")
}

